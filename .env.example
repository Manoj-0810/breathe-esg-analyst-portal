# ==============================================================================
# Breathe ESG carbon accounting platform configuration template
# Copy this file to a new file named '.env' and populate your custom values.
# ==============================================================================

# ==========================================
# Django Backend Configurations
# ==========================================
# Set to False in production
DEBUG=True

# Django Secret Key (set this to a long random secret key in production!)
SECRET_KEY=django-insecure-prod-key-for-breathe-esg-analyst-portal

# Allowed Hosts (comma-separated domains. Use * only for local development)
ALLOWED_HOSTS=*

# Database configurations
# If DB_NAME is left empty, the application automatically falls back to local SQLite (db.sqlite3).
# In production, specify your PostgreSQL database credentials:
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# ==========================================
# React Frontend Configurations
# ==========================================
# URL of your Django backend API service. In production, this should point to your deployed backend URL.
VITE_API_URL=http://localhost:8000/api
